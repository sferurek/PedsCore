{
  "buildCommand": "npm run build",
  "outputDirectory": "apps/web/dist",
  "functions": {
    "api/analytics/countries.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/analytics/countries",
      "destination": "/api/analytics/countries.js"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
