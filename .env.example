# Public frontend analytics configuration.
# VITE_* variables are embedded in the static web bundle.
VITE_ANALYTICS_PROVIDER=none
VITE_ANALYTICS_SCRIPT_URL=
VITE_ANALYTICS_DOMAIN=
VITE_UMAMI_WEBSITE_ID=
VITE_CLOUDFLARE_TOKEN=
VITE_PUBLIC_STATS_ENABLED=true
VITE_PUBLIC_STATS_ENDPOINT=

# Server-side only Umami API configuration.
# Do not expose or commit real tokens. UMAMI_API_TOKEN must never use VITE_*.
UMAMI_API_URL=
UMAMI_WEBSITE_ID=
UMAMI_API_TOKEN=
UMAMI_COUNTRY_MIN_THRESHOLD=5
UMAMI_COUNTRY_CACHE_SECONDS=3600
UMAMI_PUBLIC_STATS_ENABLED=true
